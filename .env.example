# Copy the variable names into Vercel > Project > Settings > Environment Variables.
# Never commit real values.

# Set automatically when you create a Postgres store in the Vercel dashboard
POSTGRES_URL=

# Set automatically when you create a Blob store in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# Any long random string (e.g. `openssl rand -base64 48`)
JWT_SECRET=

# Your Anthropic API key, used server-side only for report generation
ANTHROPIC_API_KEY=

# First Peek admin login, created once by visiting /api/setup
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional: if set, /api/setup requires ?key=<SETUP_KEY>
SETUP_KEY=
